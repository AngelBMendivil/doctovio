# ===========================================================================
# Plantilla de variables de entorno de Doctovio.
#
# Copia este archivo como .env y llena los valores. NUNCA subas el .env real:
# trae credenciales que dan acceso a datos clínicos.
# ===========================================================================

# --- Base de datos (PostgreSQL) ---
DATABASE_URL="postgresql://usuario:password@host:5432/base?schema=public"

# --- Autenticación / sesiones ---
# Genera uno largo y aleatorio: openssl rand -base64 48
#
# OJO: con este secreto se cifran los refresh tokens de Google Calendar. Si lo
# cambias, esas conexiones dejan de descifrarse y cada médico tiene que
# reconectar su calendario.
AUTH_SECRET=""
AUTH_COOKIE_NAME="mvp_session"
AUTH_SESSION_MAX_AGE=604800

# --- URL pública ---
# El dominio real. Con esto se arman los enlaces de prerregistro y de recetas
# que se le mandan al paciente: si está mal, los enlaces no abren.
NEXT_PUBLIC_APP_URL="https://tu-app.up.railway.app"

# --- Resend (correo). Opcional: sin esto solo falla el envío de correos. ---
RESEND_API_KEY=""
RESEND_FROM_EMAIL="notificaciones@tudominio.com"

# --- Almacenamiento de documentos (Cloudflare R2 / S3). Opcional. ---
STORAGE_ENDPOINT=""
STORAGE_REGION="auto"
STORAGE_BUCKET="mvp-pacientes-documentos"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_BASE_URL=""

# --- WhatsApp Cloud API ---
# Meta -> tu app -> Casos de uso -> WhatsApp -> Configuración de la API
WHATSAPP_ENABLED="false"
WHATSAPP_APP_ID=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WABA_ID=""
# Token de un usuario del sistema, sin caducidad. El temporal muere en 24 h.
WHATSAPP_ACCESS_TOKEN=""
# Cadena que TÚ inventas; Meta te la repite al verificar el webhook.
WHATSAPP_VERIFY_TOKEN=""
# Configuración de la app -> Básica -> Clave secreta. Valida la firma de cada
# webhook: sin ella, cualquiera que descubra la URL puede inyectar mensajes.
WHATSAPP_APP_SECRET=""
WHATSAPP_API_VERSION="v25.0"

# --- Cron / mantenimiento ---
# Protege /api/cron/reminders. Quien lo tenga puede disparar recordatorios.
CRON_SECRET=""

# --- Google Calendar (opcional) ---
# Google Cloud Console -> Credenciales -> ID de cliente OAuth (aplicación web).
# La URI de redirección debe coincidir EXACTO con la registrada en Google.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://tu-app.up.railway.app/api/integrations/google/callback"

# --- Entorno ---
NODE_ENV="production"
