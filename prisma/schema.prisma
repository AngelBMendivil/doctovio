// ============================================================================
// MVP SaaS Gestión de Pacientes — Prisma Schema
// PostgreSQL + Prisma ORM
// Convención: modelos/campos en camelCase, columnas mapeadas a snake_case.
// Multi-tenant: casi toda tabla operativa lleva organizationId.
// Soft delete: status/isActive en vez de DELETE físico.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRoleName {
  ADMIN
  DOCTOR
  ASSISTANT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  DECEASED
  DUPLICATE
  ARCHIVED
}

enum PatientSex {
  MALE
  FEMALE
  UNDETERMINED
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  FREE_UNION
  OTHER
}

enum PatientSourceType {
  PRIVATE
  INSURANCE
  COMPANY
  AGREEMENT
  DOCTOR_REFERRAL
  RECOMMENDATION
  SOCIAL_MEDIA
  INTERNET
  OTHER
}

enum ConsentType {
  PRIVACY_NOTICE
  TREATMENT_CONSENT
  DATA_SHARING
  REFERRAL_AUTHORIZATION
  OTHER
}

enum ConsentStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum AlertType {
  CRITICAL_ALLERGY
  CHRONIC_DISEASE
  PERMANENT_MEDICATION
  CARDIOVASCULAR_RISK
  PREGNANCY
  SPECIAL_CONDITION
  OTHER
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AppointmentType {
  FIRST_TIME
  FOLLOW_UP
  EXISTING_PATIENT
}

enum AppointmentStatus {
  TO_CONFIRM
  CONFIRMED
  ARRIVED
  WAITING
  IN_CONSULTATION
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum AppointmentChannel {
  PHONE
  WHATSAPP
  EMAIL
  WALK_IN
  WEBSITE
  REFERRAL
  OTHER
}

enum VisitArrivalType {
  WITH_APPOINTMENT
  WITHOUT_APPOINTMENT
  UNSCHEDULED_FOLLOWUP
  PRIORITY
  ADMINISTRATIVE_URGENCY
}

enum VisitPriority {
  NORMAL
  HIGH
  URGENT
}

enum VisitStatus {
  REGISTERED
  WAITING
  IN_TRIAGE
  IN_CONSULTATION
  COMPLETED
  LEFT
  RESCHEDULED
  CANCELLED
}

enum ConsultationType {
  GENERAL
  FOLLOW_UP
  SPECIALTY
  URGENT
  OTHER
}

enum ConsultationStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REOPENED
}

enum DiagnosisType {
  PRESUMPTIVE
  CONFIRMED
  DIFFERENTIAL
  CHRONIC
  RESOLVED
}

enum PrescriptionStatus {
  DRAFT
  ISSUED
  CANCELLED
  SUPERSEDED
}

enum MedicalOrderType {
  LAB
  IMAGING
  CLINICAL_STUDY
  THERAPY
  REFERRAL
  PROCEDURE
  OTHER
}

enum MedicalOrderStatus {
  DRAFT
  ISSUED
  CANCELLED
  COMPLETED
}

enum MedicalOrderPriority {
  ROUTINE
  URGENT
  STAT
}

enum DocumentCategory {
  IDENTIFICATION
  INSURANCE
  POLICY
  LAB_RESULT
  IMAGING
  EXTERNAL_PRESCRIPTION
  REFERRAL
  CONSENT
  ADMINISTRATIVE
  CLINICAL_PHOTO
  OTHER
}

enum PrivacyLevel {
  GENERAL
  RESTRICTED
  CONFIDENTIAL
}

enum DocumentStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum ReferralStatus {
  DRAFT
  SENT
  RECEIVED
  ACCEPTED
  REJECTED
  ATTENDED
  CLOSED
  CANCELLED
  EXPIRED
}

enum ReferralPriority {
  NORMAL
  HIGH
  URGENT
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum NotificationType {
  ACCOUNT_ACTIVATION
  PASSWORD_RESET
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELLATION
  APPOINTMENT_RESCHEDULE
  PRE_REGISTRATION_LINK
  PRESCRIPTION_ISSUED
  MEDICAL_ORDER_ISSUED
  REFERRAL_RECEIVED
  REFERRAL_ACCEPTED
  REFERRAL_REJECTED
  FOLLOW_UP_REMINDER
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

enum PublicFormTokenType {
  PRE_REGISTRATION
  APPOINTMENT_CONFIRMATION
  REFERRAL_AUTHORIZATION
}

enum PublicFormTokenStatus {
  GENERATED
  SENT
  OPENED
  STARTED
  INCOMPLETE
  SUBMITTED
  REVIEWED
  CONVERTED
  EXPIRED
  REVOKED
}

enum AuditAction {
  LOGIN
  LOGOUT
  VIEW_RECORD
  CREATE
  UPDATE
  DELETE
  SOFT_DELETE
  DOWNLOAD
  UPLOAD
  PERMISSION_CHANGE
  SEND
}

enum InsuranceAuthStatus {
  NOT_REQUIRED
  PENDING
  REQUESTED
  APPROVED
  REJECTED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}

// Origen del cobro: de bolsillo del paciente o cubierto por una aseguradora.
enum PaymentOrigin {
  PRIVATE
  INSURANCE
}

// Cobro de una consulta (cierre del ciclo del paciente).
model Payment {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  patientId      String        @map("patient_id")
  consultationId String?       @unique @map("consultation_id")
  amount         Float
  currency       String        @default("MXN") // MXN | USD
  method         PaymentMethod @default(CASH)
  origin         PaymentOrigin @default(PRIVATE) // privado o por aseguradora
  insurerId      String?       @map("insurer_id") // aseguradora, cuando origin = INSURANCE
  insurerName    String?       @map("insurer_name") // nombre congelado al momento del cobro
  reference      String? // referencia de transferencia
  notes          String?
  createdById    String        @map("created_by_id")
  createdAt      DateTime      @default(now()) @map("created_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  patient      Patient       @relation(fields: [patientId], references: [id])
  consultation Consultation? @relation(fields: [consultationId], references: [id])
  insurer      Insurer?      @relation(fields: [insurerId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, origin])
  @@map("payments")
}

// ============================================================================
// ORGANIZACIÓN / MULTIEMPRESA
// ============================================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  legalName String?  @map("legal_name")
  logoUrl   String?  @map("logo_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches           Branch[]
  users              User[]
  settings           OrganizationSettings?
  roles              Role[]
  patients           Patient[]
  appointments       Appointment[]
  visits             Visit[]
  consultations      Consultation[]
  prescriptions      Prescription[]
  medicalOrders      MedicalOrder[]
  documents          PatientDocument[]
  fileAssets         FileAsset[]
  referralsSent      MedicalReferral[]      @relation("ReferralOrgFrom")
  referralsReceived  MedicalReferral[]      @relation("ReferralOrgTo")
  notificationLogs   NotificationLog[]
  notificationTpls   NotificationTemplate[]
  publicFormTokens   PublicFormToken[]
  auditLogs          AuditLog[]
  doctorProfiles     DoctorProfile[]
  insurers           Insurer[]
  payments           Payment[]
  doctorSchedules    DoctorSchedule[]
  scheduleBlocks     ScheduleBlock[]
  appointmentHolds   AppointmentHold[]
  conversations      ConversationSession[]
  googleCalendars    GoogleCalendarConnection[]
  reminderJobs       ReminderJob[]

  @@map("organizations")
}

model Branch {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  address        String?
  city           String?
  state          String?
  postalCode     String?  @map("postal_code")
  country        String?  @default("MX")
  phone          String?
  isMain         Boolean  @default(true) @map("is_main")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by")
  updatedBy      String?  @map("updated_by")

  organization Organization  @relation(fields: [organizationId], references: [id])
  appointments Appointment[]
  visits       Visit[]
  schedules    DoctorSchedule[]

  @@index([organizationId])
  @@map("branches")
}

model OrganizationSettings {
  id                     String   @id @default(cuid())
  organizationId         String   @unique @map("organization_id")
  timezone               String   @default("America/Mexico_City")
  currency               String   @default("MXN")
  language               String   @default("es")
  defaultAppointmentMin  Int      @default(30) @map("default_appointment_minutes")
  toleranceMinutes       Int      @default(10) @map("tolerance_minutes")
  appointmentTypesJson   Json?    @map("appointment_types_json")
  consultationTypesJson  Json?    @map("consultation_types_json")
  specialtiesJson        Json?    @map("specialties_json")
  officeHoursJson        Json?    @map("office_hours_json")
  privacyNoticeHtml      String?  @map("privacy_notice_html")
  consentTemplatesJson   Json?    @map("consent_templates_json")
  prescriptionTemplate   Json?    @map("prescription_template_json")
  emailTemplatesJson     Json?    @map("email_templates_json")
  whatsappEnabled        Boolean  @default(false) @map("whatsapp_enabled")
  basePriceMxn           Float?   @map("base_price_mxn")
  basePriceUsd           Float?   @map("base_price_usd")

  // --- Reglas de agenda (las aplica el motor antes de ofrecer un horario) ---
  slotGranularityMin     Int      @default(15) @map("slot_granularity_min") // cada cuánto empieza un espacio
  bufferMinutes          Int      @default(0)  @map("buffer_minutes")       // descanso entre consultas
  minLeadMinutes         Int      @default(120) @map("min_lead_minutes")    // anticipación mínima para agendar
  maxAdvanceDays         Int      @default(90) @map("max_advance_days")     // hasta cuándo se puede agendar
  cancelMinHours         Int      @default(4)  @map("cancel_min_hours")     // anticipación mínima para cancelar
  holdMinutes            Int      @default(5)  @map("hold_minutes")         // vida de la reserva temporal
  reminderHoursBefore    Int[]    @default([24]) @map("reminder_hours_before")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("organization_settings")
}

// ============================================================================
// USUARIOS / ROLES / PERMISOS
// ============================================================================

model User {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  email          String
  passwordHash   String       @map("password_hash")
  fullName       String       @map("full_name")
  phone          String?
  primaryRole    UserRoleName @map("primary_role")
  status         UserStatus   @default(ACTIVE)
  lastLoginAt    DateTime?    @map("last_login_at")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  createdBy      String?      @map("created_by")
  updatedBy      String?      @map("updated_by")

  organization        Organization         @relation(fields: [organizationId], references: [id])
  doctorProfile        DoctorProfile?
  userRoles             UserRole[]
  appointmentsCreated   Appointment[]        @relation("AppointmentCreatedBy")
  appointmentsAsDoctor  Appointment[]        @relation("AppointmentDoctor")
  visitsAsDoctor        Visit[]              @relation("VisitDoctor")
  consultationsAsDoctor Consultation[]       @relation("ConsultationDoctor")
  prescriptionsIssued   Prescription[]       @relation("PrescriptionDoctor")
  medicalOrdersIssued   MedicalOrder[]       @relation("MedicalOrderDoctor")
  documentsUploaded     PatientDocument[]    @relation("DocumentUploadedBy")
  referralsFromDoctor   MedicalReferral[]    @relation("ReferralFromDoctor")
  referralsToDoctor     MedicalReferral[]    @relation("ReferralToDoctor")
  auditLogs             AuditLog[]
  schedules             DoctorSchedule[]
  scheduleBlocks        ScheduleBlock[]
  appointmentHolds      AppointmentHold[]
  googleCalendar        GoogleCalendarConnection?

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

model Role {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id") // null = rol de sistema (plantilla)
  name           String
  description    String?
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization      Organization?     @relation(fields: [organizationId], references: [id])
  rolePermissions    RolePermission[]
  userRoles          UserRole[]

  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model DoctorProfile {
  id                   String   @id @default(cuid())
  organizationId       String   @map("organization_id")
  userId               String   @unique @map("user_id")
  specialty            String?
  subspecialty         String?
  licenseNumber        String?  @map("license_number") // cédula profesional
  specialtyLicense     String?  @map("specialty_license") // cédula de especialidad
  licensesText         String?  @map("licenses_text") // cédulas libres, una por línea (institución + tipo + número)
  ssaNumber            String?  @map("ssa_number") // registro S.S.A. (Secretaría de Salud)
  stateRegistration    String?  @map("state_registration") // REG. EDO. (registro estatal)
  rfc                  String?  // RFC del médico (fiscal)
  signatureImageUrl    String?  @map("signature_image_url")
  photoUrl             String?  @map("photo_url")
  bio                  String?
  professionalPhone    String?  @map("professional_phone")
  professionalEmail    String?  @map("professional_email")
  modality             String?  // presencial / remoto / mixto
  acceptsReferrals     Boolean  @default(true) @map("accepts_referrals")
  listedInDirectory    Boolean  @default(true) @map("listed_in_directory")
  city                 String?
  state                String?
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([specialty])
  @@map("doctor_profiles")
}

// ============================================================================
// PACIENTES
// ============================================================================

model Patient {
  id              String         @id @default(cuid())
  organizationId  String         @map("organization_id")
  recordNumber    String         @map("record_number") // número de expediente
  firstName       String         @map("first_name")
  lastLastName    String         @map("last_name_1")
  secondLastName  String?        @map("last_name_2")
  birthDate       DateTime       @map("birth_date")
  sex             PatientSex
  gender          String?
  curp            String?
  phone           String?
  email           String?
  address         String?
  city            String?
  state           String?
  postalCode      String?        @map("postal_code")
  country         String?        @default("MX")
  occupation      String?
  maritalStatus   MaritalStatus? @map("marital_status")
  photoUrl        String?        @map("photo_url")
  adminNotes      String?        @map("admin_notes")
  status          PatientStatus  @default(ACTIVE)
  possibleDuplicateOfId String?  @map("possible_duplicate_of_id")
  admittedAt      DateTime       @default(now()) @map("admitted_at")
  dischargedAt    DateTime?      @map("discharged_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  createdBy       String?        @map("created_by")
  updatedBy       String?        @map("updated_by")

  organization        Organization                 @relation(fields: [organizationId], references: [id])
  possibleDuplicateOf  Patient?                     @relation("PatientDuplicate", fields: [possibleDuplicateOfId], references: [id])
  duplicateCandidates  Patient[]                    @relation("PatientDuplicate")
  responsibleContacts  PatientResponsibleContact[]
  emergencyContacts    PatientEmergencyContact[]
  source               PatientSource?
  insurances           PatientInsurance[]
  consents             PatientConsent[]
  alerts               PatientAlert[]
  medicalProfile       MedicalProfile?
  medicalHistory       MedicalHistory?
  allergies            Allergy[]
  chronicConditions    ChronicCondition[]
  currentMedications   CurrentMedication[]
  vaccinations         Vaccination[]
  appointments         Appointment[]
  visits               Visit[]
  consultations        Consultation[]
  prescriptions        Prescription[]
  medicalOrders        MedicalOrder[]
  documents            PatientDocument[]
  referrals            MedicalReferral[]
  publicFormTokens     PublicFormToken[]
  payments             Payment[]
  conversations        ConversationSession[]

  @@unique([organizationId, recordNumber])
  @@index([organizationId, status])
  @@index([organizationId, firstName, lastLastName])
  @@index([organizationId, phone])
  @@index([organizationId, curp])
  @@map("patients")
}

model PatientResponsibleContact {
  id                  String   @id @default(cuid())
  patientId           String   @map("patient_id")
  fullName            String   @map("full_name")
  relationship        String
  phone               String?
  email                String?
  isPrimaryContact     Boolean  @default(false) @map("is_primary_contact")
  canReceiveNotifications Boolean @default(true) @map("can_receive_notifications")
  notes               String?
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("patient_responsible_contacts")
}

model PatientEmergencyContact {
  id           String   @id @default(cuid())
  patientId    String   @map("patient_id")
  fullName     String   @map("full_name")
  relationship String
  phone        String
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("patient_emergency_contacts")
}

model PatientSource {
  id            String            @id @default(cuid())
  patientId     String            @unique @map("patient_id")
  sourceType    PatientSourceType @map("source_type")
  referringDoctorId String?       @map("referring_doctor_id")
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("patient_sources")
}

model PatientInsurance {
  id                  String              @id @default(cuid())
  patientId           String              @map("patient_id")
  insurerId           String?             @map("insurer_id") // referencia al catálogo (opcional si es texto libre)
  insurerName         String              @map("insurer_name")
  policyNumber        String?             @map("policy_number")
  affiliateNumber     String?             @map("affiliate_number")
  validFrom           DateTime?           @map("valid_from")
  validTo             DateTime?           @map("valid_to")
  planType            String?             @map("plan_type")
  authorizationStatus InsuranceAuthStatus @default(NOT_REQUIRED) @map("authorization_status")
  authorizationNumber String?             @map("authorization_number")
  checklistJson       Json?               @map("checklist_json") // [{ label, done }]
  documentAssetId     String?             @map("document_asset_id")
  isActive            Boolean             @default(true) @map("is_active")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  patient Patient  @relation(fields: [patientId], references: [id])
  insurer Insurer? @relation(fields: [insurerId], references: [id])

  @@index([patientId])
  @@index([insurerId])
  @@map("patient_insurances")
}

// Catálogo de aseguradoras por organización, con sus requisitos/protocolo.
model Insurer {
  id                        String   @id @default(cuid())
  organizationId            String   @map("organization_id")
  name                      String
  code                      String?
  contactPhone              String?  @map("contact_phone")
  contactEmail              String?  @map("contact_email")
  requiresPreAuthorization  Boolean  @default(false) @map("requires_pre_authorization")
  authorizationInstructions String?  @map("authorization_instructions")
  requiredDocuments         String?  @map("required_documents") // un requisito por línea (plantilla del checklist)
  protocolNotes             String?  @map("protocol_notes")
  coverageNotes             String?  @map("coverage_notes")
  isActive                  Boolean  @default(true) @map("is_active")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  organization      Organization       @relation(fields: [organizationId], references: [id])
  patientInsurances PatientInsurance[]
  payments          Payment[]

  @@index([organizationId])
  @@map("insurers")
}

model PatientConsent {
  id          String        @id @default(cuid())
  patientId   String        @map("patient_id")
  type        ConsentType
  status      ConsentStatus @default(PENDING)
  documentUrl String?       @map("document_url")
  acceptedAt  DateTime?     @map("accepted_at")
  acceptedIp  String?       @map("accepted_ip")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("patient_consents")
}

model PatientAlert {
  id          String        @id @default(cuid())
  patientId   String        @map("patient_id")
  type        AlertType
  severity    AlertSeverity @default(MEDIUM)
  description String
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  createdBy   String?       @map("created_by")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId, isActive])
  @@map("patient_alerts")
}

// ============================================================================
// PERFIL MÉDICO / HISTORIA CLÍNICA
// ============================================================================

model MedicalProfile {
  id                  String    @id @default(cuid())
  patientId           String    @unique @map("patient_id")
  bloodType            String?   @map("blood_type")
  isPregnant           Boolean?  @map("is_pregnant")
  hasDisability        Boolean?  @map("has_disability")
  disabilityNotes      String?   @map("disability_notes")
  attendingDoctorId    String?   @map("attending_doctor_id")
  lastVisitAt          DateTime? @map("last_visit_at")
  nextAppointmentAt    DateTime? @map("next_appointment_at")
  relevantConditions   String?   @map("relevant_conditions")

  // Declaraciones explícitas de ausencia. Distinguen "el paciente declaró no
  // tener" de "nadie preguntó": en la práctica médica se escribe "negadas", y
  // un vacío ambiguo en alergias es un riesgo real al recetar.
  allergiesNegated     Boolean   @default(false) @map("allergies_negated")
  chronicNegated       Boolean   @default(false) @map("chronic_negated")

  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("medical_profiles")
}

model MedicalHistory {
  id                        String   @id @default(cuid())
  patientId                 String   @unique @map("patient_id")
  // Antecedentes heredofamiliares
  familyDiabetes             Boolean? @map("family_diabetes")
  familyHypertension         Boolean? @map("family_hypertension")
  familyCancer               Boolean? @map("family_cancer")
  familyHeartDisease         Boolean? @map("family_heart_disease")
  familyHereditaryDisease    Boolean? @map("family_hereditary_disease")
  familyOthers               String?  @map("family_others")
  /// El paciente declaró no tener antecedentes familiares relevantes.
  /// Distinto de haber dejado la sección en blanco.
  familyNegated              Boolean  @default(false) @map("family_negated")
  // Antecedentes personales patológicos
  priorDiseases               String?  @map("prior_diseases")
  chronicDiseasesNotes         String?  @map("chronic_diseases_notes")
  surgeriesNotes                String?  @map("surgeries_notes")
  hospitalizationsNotes         String?  @map("hospitalizations_notes")
  fracturesNotes                 String?  @map("fractures_notes")
  transfusionsNotes               String?  @map("transfusions_notes")
  relevantInfectionsNotes          String?  @map("relevant_infections_notes")
  // Antecedentes personales no patológicos
  diet                        String?
  exercise                    String?
  smoking                     String?
  alcohol                     String?
  substanceUse                String?  @map("substance_use")
  housing                     String?
  hygiene                     String?
  occupationExposure          String?  @map("occupation_exposure")
  // Gineco-obstétricos
  menarche                    String?
  menstrualCycle               String?  @map("menstrual_cycle")
  pregnancies                  Int?
  deliveries                   Int?
  cSections                    Int?     @map("c_sections")
  abortions                    Int?
  lastMenstrualPeriod          DateTime? @map("last_menstrual_period")
  contraceptiveMethod          String?  @map("contraceptive_method")
  isMenopausal                 Boolean? @map("is_menopausal")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")
  updatedBy                    String?  @map("updated_by")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("medical_histories")
}

model Allergy {
